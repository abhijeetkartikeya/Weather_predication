        {
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT\n  target,\n  ROUND(CAST(metrics->>'mae' AS NUMERIC), 4) AS mae,\n  ROUND(CAST(metrics->>'rmse' AS NUMERIC), 4) AS rmse,\n  ROUND(CAST(metrics->>'r2' AS NUMERIC), 4) AS r2,\n  train_rows,\n  validation_rows,\n  trained_at\nFROM public.weather_training_runs\nWHERE lat = CAST('${lat}' AS DOUBLE PRECISION)\n  AND lon = CAST('${lon}' AS DOUBLE PRECISION)\n  AND model_version = (\n    SELECT model_version FROM public.weather_training_runs\n    WHERE lat = CAST('${lat}' AS DOUBLE PRECISION)\n      AND lon = CAST('${lon}' AS DOUBLE PRECISION)\n    ORDER BY trained_at DESC LIMIT 1\n  )\nORDER BY target;",
          "refId": "A"
        }
