      },
      "targets": [
        {
          "editorMode": "code",
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "WITH location AS (\n  SELECT CAST('${lat}' AS DOUBLE PRECISION) AS lat, CAST('${lon}' AS DOUBLE PRECISION) AS lon\n), latest_ml AS (\n  SELECT MAX(wf.issue_time) AS issue_time\n  FROM public.weather_forecast wf JOIN location l ON TRUE\n  WHERE wf.forecast_type = 'ml' AND wf.lat = l.lat AND wf.lon = l.lon\n), latest_provider AS (\n  SELECT MAX(wf.issue_time) AS issue_time\n  FROM public.weather_forecast wf JOIN location l ON TRUE\n  WHERE wf.forecast_type = 'provider' AND wf.lat = l.lat AND wf.lon = l.lon\n)\nSELECT time, metric, value FROM (\n  SELECT o.time, 'actual' AS metric, o.diffuse_radiation AS value\n  FROM public.weather_observations o JOIN location l ON TRUE\n  WHERE o.lat = l.lat AND o.lon = l.lon\n  UNION ALL\n  SELECT wf.forecast_time, 'ml_forecast', wf.diffuse_radiation\n  FROM public.weather_forecast wf JOIN location l ON TRUE JOIN latest_ml i ON wf.issue_time = i.issue_time\n  WHERE wf.forecast_type = 'ml' AND wf.lat = l.lat AND wf.lon = l.lon\n  UNION ALL\n  SELECT wf.forecast_time, 'provider_forecast', wf.diffuse_radiation\n  FROM public.weather_forecast wf JOIN location l ON TRUE JOIN latest_provider i ON wf.issue_time = i.issue_time\n  WHERE wf.forecast_type = 'provider' AND wf.lat = l.lat AND wf.lon = l.lon\n) series_data\nWHERE value IS NOT NULL AND $__timeFilter(time)\nORDER BY time;",
          "refId": "A"
        }
      ],
      "title": "DHI / Diffuse Radiation (W/m²)",
      "type": "timeseries"
    },
