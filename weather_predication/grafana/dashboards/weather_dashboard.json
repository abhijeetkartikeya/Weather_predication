    {
      "datasource": { "type": "postgres", "uid": "weather-postgres" },
      "description": "Solid = actual observations, Dashed = ML forecast, Dotted = provider forecast",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 8,
            "gradientMode": "opacity",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "pointSize": 3,
            "showPoints": "never",
            "spanNulls": true
          },
          "unit": "celsius"
        },
        "overrides": [
          {
            "matcher": { "id": "byRegexp", "options": "ml_forecast" },
            "properties": [
              { "id": "custom.lineStyle", "value": { "dash": [10, 6], "fill": "dash" } },
              { "id": "color", "value": { "fixedColor": "#FF9830", "mode": "fixed" } }
            ]
          },
          {
            "matcher": { "id": "byRegexp", "options": "provider_forecast" },
            "properties": [
              { "id": "custom.lineStyle", "value": { "dash": [4, 4], "fill": "dash" } },
              { "id": "color", "value": { "fixedColor": "#8AB8FF", "mode": "fixed" } },
              { "id": "custom.lineWidth", "value": 1 }
            ]
          },
          {
            "matcher": { "id": "byRegexp", "options": "actual" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "#73BF69", "mode": "fixed" } }
            ]
          }
        ]
      },
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 8 },
      "id": 1,
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "editorMode": "code",
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "WITH location AS (\n  SELECT CAST('${lat}' AS DOUBLE PRECISION) AS lat, CAST('${lon}' AS DOUBLE PRECISION) AS lon\n), latest_ml AS (\n  SELECT MAX(wf.issue_time) AS issue_time\n  FROM public.weather_forecast wf JOIN location l ON TRUE\n  WHERE wf.forecast_type = 'ml' AND wf.lat = l.lat AND wf.lon = l.lon\n), latest_provider AS (\n  SELECT MAX(wf.issue_time) AS issue_time\n  FROM public.weather_forecast wf JOIN location l ON TRUE\n  WHERE wf.forecast_type = 'provider' AND wf.lat = l.lat AND wf.lon = l.lon\n)\nSELECT time, metric, value FROM (\n  SELECT o.time, 'actual' AS metric, o.temperature_2m AS value\n  FROM public.weather_observations o JOIN location l ON TRUE\n  WHERE o.lat = l.lat AND o.lon = l.lon\n  UNION ALL\n  SELECT wf.forecast_time, 'ml_forecast', wf.temperature_2m\n  FROM public.weather_forecast wf JOIN location l ON TRUE JOIN latest_ml i ON wf.issue_time = i.issue_time\n  WHERE wf.forecast_type = 'ml' AND wf.lat = l.lat AND wf.lon = l.lon\n  UNION ALL\n  SELECT wf.forecast_time, 'provider_forecast', wf.temperature_2m\n  FROM public.weather_forecast wf JOIN location l ON TRUE JOIN latest_provider i ON wf.issue_time = i.issue_time\n  WHERE wf.forecast_type = 'provider' AND wf.lat = l.lat AND wf.lon = l.lon\n) series_data\nWHERE value IS NOT NULL AND $__timeFilter(time)\nORDER BY time;",
          "refId": "A"
        }
      ],
      "title": "Temperature (°C)",
      "type": "timeseries"
    },
