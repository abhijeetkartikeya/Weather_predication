      "title": "GHI — Global Horizontal Irradiance (W/m²)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "gradientMode": "scheme",
            "showPoints": "never",
            "spanNulls": true
          },
          "unit": "watt/m²"
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "ml_model" }, "properties": [{ "id": "color", "value": { "fixedColor": "#FF6B35", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "openmeteo" }, "properties": [{ "id": "color", "value": { "fixedColor": "#00B4D8", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "vedas" }, "properties": [{ "id": "color", "value": { "fixedColor": "#06D6A0", "mode": "fixed" } }] }
        ]
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "influxdb", "uid": "" },
          "query": "from(bucket: \"weather_forecast\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"weather_forecast\")\n  |> filter(fn: (r) => r._field == \"ghi\")\n  |> group(columns: [\"source\"])\n  |> aggregateWindow(every: 15m, fn: mean, createEmpty: false)\n  |> yield(name: \"ghi\")"
        }
      ]
